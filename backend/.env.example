# Copy this file to ".env" and fill in the values you have.
# The app runs even with everything blank (it just disables the optional parts).

# --- LLM: get a FREE key at https://console.groq.com/keys ---
GROQ_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile

# --- Embeddings (local, no key needed) ---
EMBED_MODEL=BAAI/bge-small-en-v1.5

# --- Vector store location ---
CHROMA_DIR=./storage/chroma

# --- Retrieval tuning ---
SIMILARITY_TOP_K=4
SIMILARITY_CUTOFF=0.35

# --- Bonus: MongoDB (leave blank to use in-memory storage) ---
# Local docker-compose value: mongodb://mongo:27017
MONGO_URI=
MONGO_DB=ai20_qa

# --- Bonus: Dappier web access (free key at https://platform.dappier.com) ---
DAPPIER_API_KEY=

# --- Where uploads are saved ---
UPLOAD_DIR=./storage/uploads

# --- Which frontend origins may call this API (comma-separated) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
